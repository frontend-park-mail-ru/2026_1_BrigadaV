<div class="bio {{className}}">
  {{> UserAvatar
    src=user.avatar
    className="bio__avatar"
  }}
  <div class="bio__meta">
    <h3 class="bio__nickname">{{user.nickname}}</h3>
    <p class="bio__location">{{user.city}}, {{user.country}}</p>
  </div>
  {{#if user.about}}
  <p class="bio__about">{{user.about}}</p>
  {{/if}}
</div>
