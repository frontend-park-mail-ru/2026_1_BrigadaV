<div class="bio {{className}}">
  {{> UserAvatar
    src=user.avatar
    className="bio__avatar"
    ref="avatar"
  }}
  <div class="bio__meta">
    <h3 class="bio__nickname" data-ref="nickname">{{user.nickname}}</h3>
    <p class="bio__location {{#unless location}}hidden{{/unless}}" data-ref="location">
      {{location}}
    </p>
  </div>
  <p class="bio__about {{#unless user.about}}hidden{{/unless}}" data-ref="about">
    {{user.about}}
  </p>
</div>
