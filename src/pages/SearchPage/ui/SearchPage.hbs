<div data-slot="header"></div>

<main class="{{s 'main'}}">
  <div class="{{s 'query'}}">
    <button class="{{s 'query__button'}}">Фильтры</button>
    <div data-slot="query" class="{{s 'query__field'}}"></div>
  </div>
  <ul class="{{s 'filters'}}">
    <li class="{{s 'filters__item'}}"><button class="{{s 'filters__button'}}">Места</button></li>
    <li class="{{s 'filters__item'}}"><button class="{{s 'filters__button'}}">Отели</button></li>
    <li class="{{s 'filters__item'}}"><button class="{{s 'filters__button'}}">Рестораны</button></li>
  </ul>

  <aside class="{{s 'aside'}}">
    <div class="{{s 'categories'}}" data-ref="category-accordion">
      <div class="{{s 'categories__summary'}}">
        <div class="{{s 'categories__header'}}" data-ref="category-toggle">
          <h3 class="{{s 'categories__title'}}">Категории</h3>
          <img src="/icons/arrow-down.svg" class="{{s 'categories__marker'}}">
        </div>

        <ul class="{{s 'categories__base'}}">
          <li class="{{s 'categories__item'}}"><input type="checkbox" class="{{s 'categories__input'}}">Музеи</li>
          <li class="{{s 'categories__item'}}"><input type="checkbox" class="{{s 'categories__input'}}">Галереи</li>
          <li class="{{s 'categories__item'}}"><input type="checkbox" class="{{s 'categories__input'}}">Парки</li>
        </ul>
      </div>

      <div class="{{s 'categories__extended-wrapper'}}" data-ref="extended-wrapper">
        <ul class="{{s 'categories__extended'}}">
          <li class="{{s 'categories__item'}}"><input type="checkbox" class="{{s 'categories__input'}}">Площади</li>
          <li class="{{s 'categories__item'}}"><input type="checkbox" class="{{s 'categories__input'}}">Зоопарки</li>
        </ul>
      </div>
    </div>
  </aside>

  <div data-slot="place-list" class="{{s 'place-list'}}"></div>
</main>
