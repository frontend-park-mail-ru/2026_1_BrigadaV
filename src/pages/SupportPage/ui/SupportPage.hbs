<div class="{{s 'support-page'}}">
  <h1 class="{{s 'support-page__title'}}">Поддержка</h1>

  <div class="{{s 'support-page__create-section'}}">
    <h2 class="{{s 'support-page__title'}}">Новое обращение</h2>
    <form data-ref="create-form">
      <label>Категория:</label>
      <select data-ref="category-select" name="category">
        <option value="bug">Баг</option>
        <option value="feature">Предложение</option>
        <option value="complaint">Жалоба</option>
      </select>

      <div data-ref="name-field"></div>
      <div data-ref="email-field"></div>
      <div data-ref="description-field"></div>

      <button type="button" data-ref="submit-btn">Отправить</button>
    </form>
  </div>

  {{#if successMessage}}
    <div class="{{s 'support-page__success'}}">{{successMessage}}</div>
  {{/if}}

  {{#if tickets.length}}
    <div class="{{s 'support-page__my-tickets'}}">
      <h2>Мои обращения</h2>
      <div class="{{s 'support-page__list'}}">
        {{#each tickets}}
          <div class="{{s 'support-page__ticket'}}">
            <span class="{{s 'support-page__ticket-category'}}">[{{categoryLabel}}]</span>
            <span class="{{s 'support-page__ticket-description'}}">{{body}}</span>
          </div>
        {{/each}}
      </div>
    </div>
  {{/if}}
</div>