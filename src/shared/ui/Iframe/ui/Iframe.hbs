<div class="{{s 'wrapper'}} {{#unless visible}}{{s 'wrapper--hidden'}}{{/unless}}" style="width:{{width}}; height:{{height}};">
  {{#if visible}}
    {{#if isIdle}}<div class="{{s 'state'}} {{s 'state--idle'}}">Контент не загружен</div>{{/if}}
    {{#if isLoading}}<div class="{{s 'state'}} {{s 'state--loading'}}">Загрузка...</div>{{/if}}
    {{#if isError}}<div class="{{s 'state'}} {{s 'state--error'}}">Ошибка загрузки</div>{{/if}}
    <iframe
      src="{{src}}"
      title="{{title}}"
      sandbox="{{sandbox}}"
      allow="{{allow}}"
      class="{{s 'iframe'}} {{#if isLoaded}}{{s 'iframe--loaded'}}{{/if}}"
      referrerpolicy="no-referrer"
      loading="lazy"
      style="width:100%; height:100%; border:none;"
    ></iframe>
  {{/if}}
</div>